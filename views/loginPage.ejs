<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link rel="stylesheet" href="/login.css">
</head>
<body>

    <header>
        <nav class="navbar">
            <h1>Secret Clubhouse</h1>

            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/signup">Sign Up</a>
            </div>
        </nav>
    </header>

    <main>

        <section class="loginCard">

            <h2>Welcome Back</h2>

            <p>
                Log in to continue exploring the Secret Clubhouse.
            </p>

            <form action="/login" method="post">

                <label for="email">Email</label>

                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="Enter your email"
                    required
                >

                <label for="password">Password</label>

                <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="Enter your password"
                    required
                >

                <button type="submit">
                    Log In
                </button>

            </form>

            <p class="bottomText">
                Don't have an account?
                <a href="/signup">Create one</a>
            </p>

        </section>

    </main>

</body>
</html>