<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secret Clubhouse</title>

    <link rel="stylesheet" href="/homepage.css">
</head>
<body>

    <header>
        <nav class="navbar">
            <h1>Secret Clubhouse</h1>

            <div class="nav-links">
                <a href="/signup">Sign Up</a>
                <a href="/login">Login</a>
                <a href="/joinClub">Join Club</a>
            </div>
        </nav>

        <div class="hero">
            <h2>Welcome to the Secret Clubhouse</h2>

            <p>
                Read anonymous posts from members around the world.
                Become a member to reveal who wrote each message.
            </p>
        </div>
    </header>

    <main>

        <section class="messagesSection">
            <h2>Latest Messages</h2>

            <div class="messagesContainer">

                <% messages.forEach((message) => { %>

                    <article class="messageCard">

                        <h3><%= message.title %></h3>

                        <p class="messageText">
                            <%= message.message %>
                        </p>

                        <p class="author">
                            Posted by <strong>Anonymous</strong>
                        </p>

                    </article>

                <% }) %>

            </div>
        </section>

    </main>

</body>
</html>